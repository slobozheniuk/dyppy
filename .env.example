# Supabase PostgreSQL Connection (used by Prisma for seeding/migrations)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Get these values from your Supabase project:
#   Dashboard → Settings → Database → Connection string
#
# DATABASE_URL: Uses the connection pooler (port 6543) via PgBouncer.
#   Used by Prisma Client at runtime for queries.
#
# DIRECT_URL: Direct connection (port 5432), bypasses the pooler.
#   Used by Prisma Migrate / db push for schema changes.
#
# ═══════════════════════════════════════════════════════════════════════════════

# Connect to Supabase via connection pooling (for Prisma / db:seed)
DATABASE_URL="postgresql://postgres.[id]:[password]@[address]:[port]/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres.[id]:[password]@[address]:[port]:5432/postgres"


# Supabase JS Client (used by the React frontend)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Get these values from: Supabase Dashboard → Settings → API
#
# VITE_SUPABASE_URL: Your project URL (https://<ref>.supabase.co)
# VITE_SUPABASE_ANON_KEY: The anon/public key — safe to expose in the browser.
#   Relies on RLS policies to restrict write access.
#
# ═══════════════════════════════════════════════════════════════════════════════

VITE_SUPABASE_URL="https://<ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="<your-anon-key>"


# Admin Write Script (used by scripts/admin-writer.js only — NEVER in frontend)
# ═══════════════════════════════════════════════════════════════════════════════
#
# SUPABASE_URL: Same project URL as above (without VITE_ prefix)
# SUPABASE_SERVICE_ROLE_KEY: Bypasses RLS — keep this secret.
#   Get it from: Supabase Dashboard → Settings → API → service_role key
#
# ═══════════════════════════════════════════════════════════════════════════════

SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<your-service-role-key>"
